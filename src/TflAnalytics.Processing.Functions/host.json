{
  "version": "2.0",
  "logging": {
    "logLevel": {
      "Default": "Information",
      "System.Net.Http.HttpClient": "Warning"
    }
  },
  "extensions": {
    "queues": {
      "batchSize": 8,
      "newBatchThreshold": 4,
      "maxDequeueCount": 5,
      "visibilityTimeout": "00:00:30",
      "messageEncoding": "base64"
    },
    "eventHubs": {
      "maxEventBatchSize": 64,
      "prefetchCount": 128
    },
    "durableTask": {
      "hubName": "TflAnalyticsAlerts"
    }
  }
}
